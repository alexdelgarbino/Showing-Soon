    <item>
      <title>Remake</title>
      <link>https://www.imdb.com/title/tt37660544/</link>
      <description>&lt;div style=&quot;font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 700px; line-height: 1.6; color: #333;&quot;&gt;
        &lt;div style='margin-bottom: 20px;'&gt;&lt;img src='https://image.tmdb.org/t/p/w500/7Q2NBPXyK0hKnE7o58sPhQ0eTQ5.jpg' alt='Movie Backdrop' style='max-width: 100%; height: auto; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);' /&gt;&lt;/div&gt;
